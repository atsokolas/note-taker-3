# Ignore environment files
.env
node_modules/
.tools/
server/logs/
.vercel
.gstack/
.superpowers/

# Local tool caches and test artifacts
.playwright-cli/
test-results/
tmp/
.cursor/hooks/state/
.codex-qa-*.png

# Local search-performance exports can contain private query/page performance data.
data/growth/search-console/*
!data/growth/search-console/.gitkeep

# Local Xcode workspace metadata
ios/**/xcuserdata/
ios/**/*.xcworkspace/

# Sync-conflict copies (iCloud / Dropbox " 2.ext" artifacts)
*\ [0-9].js
*\ [0-9].jsx
*\ [0-9].ts
*\ [0-9].tsx
*\ [0-9].md
*\ [0-9].css
*\ [0-9].json
*\ [0-9].log
*\ [0-9].html
