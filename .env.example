## Core
PORT=5500
JWT_SECRET=replace_me
MONGODB_URI=mongodb://localhost:27017/note-taker

## Curated public proof registry
## Each value may be a shared WikiPage id or slug. When blank, the API uses a
## conservative shared-page title/type match; production should pin all six.
PUBLIC_PROOF_ALPHABET_PAGE=
PUBLIC_PROOF_MARGIN_OF_SAFETY_PAGE=
PUBLIC_PROOF_CIRCLE_OF_COMPETENCE_PAGE=
PUBLIC_PROOF_MARKET_MAP_PAGE=
PUBLIC_PROOF_LIVE_QUESTION_PAGE=
PUBLIC_PROOF_NOEIS_REPO_PAGE=

## AI flags
AI_ENABLED=true
AI_GENERATION_ENABLED=false
AI_SERVICE_URL=
AI_SHARED_SECRET=replace_me
AI_SERVICE_TIMEOUT_MS=30000
AI_SERVICE_RETRIES=1
AI_SYNTH_UPSTREAM_TIMEOUT_MS=12000
AI_SYNTH_UPSTREAM_RETRIES=0
AI_SYNTH_MAX_ITEMS=60
AI_SYNTH_MAX_CHARS=25000
AI_SYNTH_MAX_ITEM_CHARS=1200

## Hugging Face embeddings
HF_TOKEN=replace_me
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

## Text generation
## If OPENROUTER_API_KEY is set, Noeis uses OpenRouter for text generation and
## keeps Hugging Face for embeddings. If it is unset, text generation falls back
## to the Hugging Face router variables below.
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini
OPENROUTER_TEXT_MODEL_FALLBACKS=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://www.noeis.io
OPENROUTER_APP_TITLE=Noeis

## Hugging Face text fallback
HF_PROVIDER=groq
HF_TEXT_MODEL=openai/gpt-oss-120b
HF_TEXT_MODEL_FALLBACKS=openai/gpt-oss-120b:cerebras,openai/gpt-oss-120b:fireworks-ai,Qwen/Qwen3-Next-80B-A3B-Instruct:novita
HF_AGENT_CHAT_ROUTES=openai/gpt-oss-120b:groq,openai/gpt-oss-120b:cerebras,openai/gpt-oss-120b:fireworks-ai,Qwen/Qwen3-Next-80B-A3B-Instruct:novita
HF_AGENT_TOOL_ROUTES=openai/gpt-oss-120b:groq,openai/gpt-oss-120b:cerebras,openai/gpt-oss-120b:fireworks-ai,Qwen/Qwen3-Coder-Next:novita
HF_AGENT_STRUCTURE_ROUTES=openai/gpt-oss-120b:groq,openai/gpt-oss-120b:cerebras,openai/gpt-oss-120b:fireworks-ai,google/gemma-4-26B-A4B-it:novita
HF_AGENT_DEEP_AUDIT_ROUTES=Qwen/Qwen3-Next-80B-A3B-Thinking:novita,deepseek-ai/DeepSeek-V4-Pro:together,openai/gpt-oss-120b:groq
HF_ROUTER_BASE_URL=https://router.huggingface.co/v1
HF_MODELS_BASE_URL=https://router.huggingface.co/hf-inference/models
HF_TIMEOUT_MS=30000
AI_SYNTH_MAX_OUTPUT_ITEM_CHARS=220
AI_SYNTH_MAX_ATTEMPTS=1
AI_SYNTH_MAX_LATENCY_MS=12000
AI_SYNTH_MAX_TOKENS=260

## Agent harness / smoke tests
AGENT_BAKEOFF_OUTCOME_TELEMETRY_PATH=
AGENT_BAKEOFF_OUTCOME_TELEMETRY_URL=
AGENT_BAKEOFF_OUTCOME_TELEMETRY_TOKEN=
AGENT_BAKEOFF_PROMOTION_MIN_PASS_RATE=1
AGENT_BAKEOFF_PROMOTION_MAX_AVG_LATENCY_MS=30000
AGENT_BAKEOFF_PROMOTION_MIN_CASES=1
AGENT_BAKEOFF_PROMOTION_MAX_OVERPREDICTING=0
AGENT_BAKEOFF_FAIL_ON_ALERT=false
AGENT_APPROVAL_SMOKE_BASE_URL=http://127.0.0.1:5001
AGENT_APPROVAL_SMOKE_TOKEN=
AGENT_APPROVAL_SMOKE_ACTION=reject
AGENT_APPROVAL_SMOKE_OUTPUT_DIR=tmp/agent-approval-smoke-runs

## Qdrant
QDRANT_HOST=http://localhost:6333
QDRANT_API_KEY=
# Wiki storage governor. The worker is report-only unless APPLY is explicitly enabled.
WIKI_STORAGE_GOVERNOR_APPLY=false
WIKI_STORAGE_GOVERNOR_DISABLED=false
WIKI_STORAGE_GOVERNOR_RUN_ON_START=true
WIKI_STORAGE_GOVERNOR_INTERVAL_MS=21600000
WIKI_STORAGE_RETENTION_DAYS=45
WIKI_STORAGE_PRESSURE_RETENTION_DAYS=14
WIKI_STORAGE_HIGH_WATER_BYTES=440401920
WIKI_STORAGE_GOVERNOR_BATCH_SIZE=2500
WIKI_STORAGE_REVISION_PAGE_LIMIT=10
