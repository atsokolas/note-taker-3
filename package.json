{
  "name": "note-taker-3-1",
  "version": "1.0.0",
  "description": "Note-taking Chrome extension with web UI and MongoDB backend",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "qa:seed": "node scripts/seed_editor_qa.js",
    "agent:harness": "node scripts/run_agent_harness.js",
    "agent:harness:realistic": "node scripts/run_agent_harness.js --fixture-set=realistic",
    "agent:harness:live": "node scripts/run_agent_harness.js --live",
    "agent:harness:integrations": "node scripts/run_agent_harness.js --integration-dry-run --workflow=librarian,memory_steward",
    "agent:harness:ci": "node scripts/run_agent_harness_regression.js",
    "agent:harness:ci:live": "node scripts/run_agent_harness_regression.js --include-live",
    "agent:bakeoff": "node scripts/run_agent_model_bakeoff.js",
    "agent:approval-smoke": "node scripts/run_agent_memory_approval_smoke.js",
    "smoke:server": "node scripts/run_server_smoke.js",
    "smoke:imports": "node scripts/test_import_integrations_smoke.js",
    "test:import-helpers": "node scripts/test_import_helpers.js",
    "test:import-session-routes": "node scripts/test_import_session_routes.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atsokolas/note-taker-3.git"
  },
  "keywords": [],
  "author": "Athan Tsokolas",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/atsokolas/note-taker-3/issues"
  },
  "homepage": "https://github.com/atsokolas/note-taker-3#readme",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.8.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.12.0",
    "mongoose": "^8.9.5",
    "nodemailer": "^6.10.1",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "react-router-dom": "^7.6.2",
    "pdfkit": "^0.15.0",
    "archiver": "^7.0.1",
    "@huggingface/inference": "^2.8.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
